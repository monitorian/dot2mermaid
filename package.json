{
  "name": "dot2mermaid",
  "type": "module",
  "version": "0.0.1",
  "description": "Convert Graphviz DOT graphs to Mermaid flowcharts for documentation and CI-generated diagrams.",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "bin": {
    "dot2mermaid": "./bin/cli.js"
  },
  "files": [
    "bin",
    "docs",
    "examples",
    "src",
    "README.md"
  ],
  "scripts": {
    "inspect": "node bin/inspect.js",
    "convert": "node bin/cli.js",
    "test": "node --test"
  },
  "keywords": [
    "dot",
    "graphviz",
    "mermaid",
    "flowchart",
    "diagram",
    "markdown",
    "documentation",
    "ci"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monitorian/dot2mermaid.git"
  },
  "author": "monitorian",
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.7",
    "lodash": "^4.17.21",
    "vis-network": "^9.1.2"
  },
  "devDependencies": {
    "babel-root-import": "^4.1.8",
    "typescript": "^4.6.3"
  }
}
